<UserControl
    x:Class="LegendGroupServerSystem.WPf.Views.Pages.LogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LegendGroupServerSystem.WPf.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:LegendGroupServerSystem.WPf.ViewModels.Pages"
    xmlns:behaviors="clr-namespace:LegendGroupServerSystem.WPf.Behaviors"
    d:DataContext="{d:DesignInstance Type=pages:LogViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel
            Margin="0,0,0,10"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Padding="10,5"
                Command="{Binding ClearLogsCommand}"
                Content="清理日志" />
        </StackPanel>
        <ListBox
            Grid.Row="1"
            behaviors:AutoScrollBehavior.Enable="True"
            HorizontalContentAlignment="Stretch"
            BorderThickness="0"
            ItemsSource="{Binding Logs}"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.ScrollUnit="Pixel"
            VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBox
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        IsReadOnly="True"
                        Text="{Binding Mode=OneWay}"
                        TextWrapping="Wrap" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
