<Window
    x:Class="legendGroupServerSystem.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:legendGroupServerSystem.Wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:LegendGroupServerSystem.WPf.ViewModels"
    Title="传奇功能网关"
    Width="700"
    Height="650"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    Closing="Window_Closing"
    StateChanged="Window_StateChanged"
    mc:Ignorable="d">
    <DockPanel>
        <StackPanel
            Background="#1FA3C6"
            DockPanel.Dock="Top"
            Orientation="Horizontal">
            <RadioButton IsChecked="{Binding IsLogSelected}" Style="{StaticResource NavRadioButtonStyle}">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,5"
                        HorizontalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="24"
                        Text="&#xE70F;" />
                    <TextBlock HorizontalAlignment="Center" Text="系统日志" />
                </StackPanel>
            </RadioButton>
            <RadioButton IsChecked="{Binding IsSettingsSelected}" Style="{StaticResource NavRadioButtonStyle}">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,5"
                        HorizontalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="24"
                        Text="&#xE713;" />
                    <TextBlock HorizontalAlignment="Center" Text="系统设置" />
                </StackPanel>
            </RadioButton>
        </StackPanel>
        <ContentControl Content="{Binding CurrentView}" />
    </DockPanel>
</Window>
